# ==============================================
# Data Janitor — Environment Configuration
# ==============================================
# Copy this file to .env and fill in your secrets.
# Never commit .env to version control.

# --- Application ---
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-256-bit-random
ENCRYPTION_KEY=change-me-32-byte-key-for-aes-gcm

# --- Database ---
DATABASE_URL=postgresql+asyncpg://janitor:janitor@localhost:5432/data_janitor

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# --- OAuth Providers ---
# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:8000/crm/callback?salesforce

# HubSpot
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:8000/crm/callback?hubspot

# Google (email parsing)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/email/callback/google

# Microsoft (email parsing)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8000/email/callback/microsoft

# --- Enrichment APIs ---
CLEARBIT_API_KEY=
HUNTER_API_KEY=
APOLLO_API_KEY=

# --- Sentry ---
SENTRY_DSN=

# --- Proxy (optional, for scraping) ---
PROXY_URL=
